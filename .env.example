# =============================================
# Alex-IO Production Environment Variables
# Copy this file to .env and fill in real values
# Never commit real secrets!
# =============================================

# === Core (REQUIRED) ===
DATABASE_URL=postgresql://user:password@localhost:5432/alexio
NEXTAUTH_SECRET=your-super-secret-32-char-string-here   # generate with: openssl rand -hex 32
ADMIN_KEY=your-admin-key-here                           # used for internal admin endpoints

# === Next.js / Auth ===
NEXTAUTH_URL=https://api.alex-io.com

# === HubSpot ===
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=https://api.alex-io.com/api/hubspot/callback
HUBSPOT_WEBHOOK_SECRET=
HUBSPOT_ACCESS_TOKEN=                                           # optional but recommended

# === Microsoft Graph (Email) ===
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_MAILBOX_FROM=alex@alex-io.com

# === Redis (Upstash) ===
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# === Optional / Development ===
NODE_ENV=production
# OPENAI_API_KEY=sk-...                                           # only needed if you still use LLM fallback

# =============================================
# How to generate NEXTAUTH_SECRET:
#   openssl rand -hex 32
# =============================================